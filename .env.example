# ── GPU Server (LOCAL LLM — all calls stay on your network) ──
# Change MAIN_MODEL to match whatever model you loaded in vLLM/Ollama
MAIN_MODEL=gpt-oss-20b
QUERY_URL=http://localhost:11434
VISION_URL=http://localhost:11435
LOCAL_BASE_URL=http://localhost
REMOTE_GPU=false

# ── Cloud LLM Keys (OPTIONAL — only needed if you re-enable cloud fallbacks) ──
# By default, cloud fallbacks are DISABLED (see constants.py SWITCHES).
# Leave these empty for fully air-gapped / on-premise deployment.
API_KEY_1=
API_KEY_2=
API_KEY_3=
API_KEY_4=
API_KEY_5=
API_KEY_6=

# OpenAI (leave empty for GPU-only mode)
OPENAI_API=

# INTERNAL API (optional)
USE_INTERNAL=false
INTERNAL_BASE_URL=
INTERNAL_CLIENT_KEY=
INTERNAL_API_TOKEN=
INTERNAL_USER_EMAIL=
INTERNAL_MODEL_ID=

# SMTP (for email digest)
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USER=alerts@company.com
SMTP_PASSWORD=
SMTP_FROM=alerts@company.com
SMTP_USE_TLS=true

# GitHub (for trending repos)
GITHUB_TOKEN=ghp_...

# JWT Auth
SECRET_KEY=your-jwt-secret

# Data directory
DATA_DIR=./data
